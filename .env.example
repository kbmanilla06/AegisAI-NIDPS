# Copy to .env and set local values. Never commit .env.
AEGIS_ENVIRONMENT=development
AEGIS_PREVENTION_MODE=simulation
AEGIS_API_PORT=8000
AEGIS_DASHBOARD_PORT=5173
AEGIS_ALLOWED_ORIGINS=http://localhost:5173
AEGIS_INGESTION_MAX_UPLOAD_BYTES=8388608
AEGIS_INGESTION_MAX_RECORDS=10000
AEGIS_INGESTION_MAX_UNIQUE_FLOWS=5000
AEGIS_INGESTION_MAX_PROCESSING_SECONDS=120
AEGIS_DETECTION_MAX_GROUPS=5000
AEGIS_DETECTION_MAX_ALERTS=1000
AEGIS_DETECTION_MAX_SIGNALS=10000
AEGIS_DETECTION_MAX_EVIDENCE_PER_ALERT=100
AEGIS_DETECTION_MAX_ACTIVE_RULES=50
AEGIS_DETECTION_SOFT_LIMIT_SECONDS=60
AEGIS_DETECTION_HARD_LIMIT_SECONDS=75
AEGIS_LIVE_ALERT_QUEUE_SIZE=100
AEGIS_FEATURE_MAX_SCHEMAS=10
AEGIS_FEATURE_MAX_FEATURES=128
AEGIS_FEATURE_MAX_WINDOWS=4
AEGIS_FEATURE_MAX_FLOWS=10000
AEGIS_FEATURE_MAX_OUTPUT_ROWS=100000
AEGIS_FEATURE_MAX_OUTPUT_BYTES=67108864
AEGIS_FEATURE_SOFT_LIMIT_SECONDS=120
AEGIS_FEATURE_HARD_LIMIT_SECONDS=135
AEGIS_FEATURE_RETENTION_DAYS=30
AEGIS_SYNTHETIC_MAX_FLOWS=10000
AEGIS_SYNTHETIC_MAX_GROUPS=120
AEGIS_SYNTHETIC_GLOBAL_SEED=20260714
AEGIS_SYNTHETIC_SOFT_LIMIT_SECONDS=120
AEGIS_SYNTHETIC_HARD_LIMIT_SECONDS=135
AEGIS_SYNTHETIC_PENDING_TIMEOUT_SECONDS=60
AEGIS_SYNTHETIC_RETENTION_DAYS=30

# Required local secret; generate a unique value before starting Compose.
POSTGRES_PASSWORD=

# Sprint 1 sessions and CSRF tokens are generated randomly and stored only as hashes.
# No static browser-session secret belongs in this file.
