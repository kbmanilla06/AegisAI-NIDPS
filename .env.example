# Copy to .env and set local values. Never commit .env.
AEGIS_ENVIRONMENT=development
AEGIS_PREVENTION_MODE=simulation
AEGIS_API_PORT=8000
AEGIS_DASHBOARD_PORT=5173
AEGIS_ALLOWED_ORIGINS=http://localhost:5173

# Required local secret; generate a unique value before starting Compose.
POSTGRES_PASSWORD=

# Session secrets are implemented in Sprint 1. Do not add them to this template yet.
